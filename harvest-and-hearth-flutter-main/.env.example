# ── Clerk (đăng nhập ứng dụng) ────────────────────────────────────────────────
# Dashboard: https://dashboard.clerk.com → API Keys → Publishable key
CLERK_PUBLISHABLE_KEY=pk_test_YWRhcHRlZC1saW9uLTQzLmNsZXJrLmFjY291bnRzLmRldiQ

# ── API backend (MongoDB Atlas qua Node) ─────────────────────────────────────
# Chuỗi MONGODB_URI (Atlas) chỉ đặt trong server/.env — KHÔNG đưa vào app Flutter.
# Xem: server/.env.example và server/README.md
#
# URL gốc của API Node (vd. http://10.0.2.2:8787 khi emulator Android gọi máy dev)
API_BASE_URL=https://harvest-and-hearth-flutter-backend.onrender.com

# Nút mô phỏng thời gian (FAB góc trái): mặc định BẬT trên release; đặt false để ẩn (vd. bản Store).
# ENABLE_TIME_SIMULATOR=false

# ── Tài khoản thử (tuỳ chọn) ─────────────────────────────────────────────────
# Tạo user cùng email/mật khẩu trong Clerk Dashboard trước. Khi đặt cả hai giá trị
# dưới đây, màn đăng nhập hiện nút "Dùng tài khoản thử" để xem / sao chép (không tự điền form Clerk).
TEST_ACCOUNT_EMAIL=test@harvestandhearth.app
TEST_ACCOUNT_PASSWORD=!testPassword123!
ENABLE_TIME_SIMULATOR=true
